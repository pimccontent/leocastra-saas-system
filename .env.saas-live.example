# Copy to .env.saas-live before running docker compose.
# IMPORTANT:
# - Use strong secrets in production.
# - SAAS_PUBLIC_API_URL must be the public HTTPS URL your browser can reach.

SAAS_DB_NAME=leocastra_saas
SAAS_DB_USER=saas_user
SAAS_DB_PASSWORD=change-this-db-password

# Public API URL used by saas-web build (browser + SSR metadata requests).
# Example:
# SAAS_PUBLIC_API_URL=https://saas-api.yourdomain.com/api
SAAS_PUBLIC_API_URL=http://127.0.0.1:3001/api

# Host ports on your server (you can keep defaults).
SAAS_BACKEND_PORT=3001
SAAS_WEB_PORT=3000

# Backend app settings
AUTH_JWT_SECRET=change-this-auth-secret-to-32-plus-chars
SUPERADMIN_EMAIL=superadmin@leocastra.local
SUPERADMIN_PASSWORD=SuperAdmin123!

# Optional payment provider secrets
PAYSTACK_WEBHOOK_SECRET=
BINANCEPAY_WEBHOOK_SECRET=
